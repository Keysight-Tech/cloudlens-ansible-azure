{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "title": "Keysight CloudLens Virtual Packet Broker (vPB) from Azure Marketplace",
    "description": "One-click deployment of a CloudLens Virtual Packet Broker v3.15.0 from Azure Marketplace. Provisions a single vPB VM with three NICs (management, ingress, egress), accelerated networking on the data-plane NICs, a public IP on the management NIC, and an NSG that opens SSH, HTTPS, and VXLAN ports (4789, 10800-10801). Default CLI credentials: admin / ixia (change immediately). SSH is reachable about 60 seconds after deploy; full vPB initialization takes 5 to 10 minutes.",
    "author": "Keysight Technologies"
  },
  "parameters": {
    "vmName": {
      "type": "string",
      "defaultValue": "vpb",
      "metadata": {
        "description": "Name of the Virtual Packet Broker VM. Used as the computer name and as a prefix for the public IP, NSG, the three NICs, and (when creating one) the VNet."
      }
    },
    "adminUsername": {
      "type": "string",
      "defaultValue": "azureuser",
      "metadata": {
        "description": "Linux admin username used for SSH access to the underlying VM. KCOS-based vPB images expose OS-level SSH on port 9022 (NOT the default 22): ssh azureuser@<public-ip> -p 9022. The vPB CLI uses its own separate admin account (admin / ixia) reachable as a two-hop SSH on port 2222 from inside the OS shell."
      }
    },
    "adminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "Linux admin password for SSH access. Must be 12+ characters and include uppercase, lowercase, a digit, and a symbol. This is the OS-level password, not the vPB CLI password."
      }
    },
    "vmSize": {
      "type": "string",
      "defaultValue": "Standard_D8s_v3",
      "allowedValues": [
        "Standard_D8s_v3",
        "Standard_D16s_v3",
        "Standard_D32s_v3"
      ],
      "metadata": {
        "description": "VM size. Minimum Standard_D8s_v3 is required: vPB needs three NICs with accelerated networking, and smaller D-series sizes do not support 3+ NICs. Scale up for higher mirror throughput."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for deployment. Defaults to the resource group location. Pick the region that hosts the workloads you want to mirror."
      }
    },
    "vnetName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Existing VNet name to deploy into. Leave blank to create a new VNet with three subnets (vpb-mgmt, vpb-ingress, vpb-egress)."
      }
    },
    "existingVnetResourceGroup": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Resource group of the existing VNet (only used when VNet name is set). Leave blank to use the current resource group."
      }
    },
    "addressSpace": {
      "type": "string",
      "defaultValue": "10.50.0.0/16",
      "metadata": {
        "description": "VNet address space in CIDR notation. Only used when creating a new VNet. Must not overlap with VNets you plan to peer with."
      }
    },
    "mgmtSubnetPrefix": {
      "type": "string",
      "defaultValue": "10.50.2.0/24",
      "metadata": {
        "description": "Management subnet prefix in CIDR notation. Hosts the management NIC (the one with the public IP and SSH access). Only used when creating a new VNet."
      }
    },
    "ingressSubnetPrefix": {
      "type": "string",
      "defaultValue": "10.50.3.0/24",
      "metadata": {
        "description": "Ingress subnet prefix in CIDR notation. Receives mirrored traffic from sensors and Azure Gateway Load Balancer. Only used when creating a new VNet."
      }
    },
    "egressSubnetPrefix": {
      "type": "string",
      "defaultValue": "10.50.4.0/24",
      "metadata": {
        "description": "Egress subnet prefix in CIDR notation. Forwards processed mirror traffic to your monitoring tools. Only used when creating a new VNet."
      }
    }
  },
  "variables": {
    "createNewVnet": "[empty(parameters('vnetName'))]",
    "vnetResourceGroup": "[if(empty(parameters('existingVnetResourceGroup')), resourceGroup().name, parameters('existingVnetResourceGroup'))]",
    "effectiveVnetName": "[if(variables('createNewVnet'), concat(parameters('vmName'), '-vnet'), parameters('vnetName'))]",
    "mgmtSubnetName": "vpb-mgmt",
    "ingressSubnetName": "vpb-ingress",
    "egressSubnetName": "vpb-egress",
    "mgmtSubnetId": "[if(variables('createNewVnet'), resourceId('Microsoft.Network/virtualNetworks/subnets', variables('effectiveVnetName'), variables('mgmtSubnetName')), resourceId(variables('vnetResourceGroup'), 'Microsoft.Network/virtualNetworks/subnets', variables('effectiveVnetName'), variables('mgmtSubnetName')))]",
    "ingressSubnetId": "[if(variables('createNewVnet'), resourceId('Microsoft.Network/virtualNetworks/subnets', variables('effectiveVnetName'), variables('ingressSubnetName')), resourceId(variables('vnetResourceGroup'), 'Microsoft.Network/virtualNetworks/subnets', variables('effectiveVnetName'), variables('ingressSubnetName')))]",
    "egressSubnetId": "[if(variables('createNewVnet'), resourceId('Microsoft.Network/virtualNetworks/subnets', variables('effectiveVnetName'), variables('egressSubnetName')), resourceId(variables('vnetResourceGroup'), 'Microsoft.Network/virtualNetworks/subnets', variables('effectiveVnetName'), variables('egressSubnetName')))]",
    "pipName": "[concat(parameters('vmName'), '-mgmt-pip')]",
    "nsgName": "[concat(parameters('vmName'), '-mgmt-nsg')]",
    "mgmtNicName": "[concat(parameters('vmName'), '-mgmt-nic')]",
    "ingressNicName": "[concat(parameters('vmName'), '-ingress-nic')]",
    "egressNicName": "[concat(parameters('vmName'), '-egress-nic')]",
    "imagePublisher": "keysight-technologies-cloudlens",
    "imageOffer": "keysight-cloudlens-virtual-packet-broker",
    "imageSku": "cloudlens-virtual-packet-broker-3-15-0_1"
  },
  "resources": [
    {
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2024-05-01",
      "name": "[variables('pipName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard"
      },
      "properties": {
        "publicIPAllocationMethod": "Static",
        "dnsSettings": {
          "domainNameLabel": "[concat(parameters('vmName'), '-', uniqueString(resourceGroup().id))]"
        }
      }
    },
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2024-05-01",
      "name": "[variables('nsgName')]",
      "location": "[parameters('location')]",
      "properties": {
        "securityRules": [
          {
            "name": "AllowSSH",
            "properties": {
              "priority": 100,
              "protocol": "Tcp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "22"
            }
          },
          {
            "name": "AllowKCOSSsh",
            "properties": {
              "priority": 105,
              "protocol": "Tcp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "9022"
            }
          },
          {
            "name": "AllowHTTPS",
            "properties": {
              "priority": 110,
              "protocol": "Tcp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "443"
            }
          },
          {
            "name": "AllowVxlanStandard",
            "properties": {
              "priority": 200,
              "protocol": "Udp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "4789"
            }
          },
          {
            "name": "AllowVxlanKeysight",
            "properties": {
              "priority": 210,
              "protocol": "Udp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "10800-10801"
            }
          }
        ]
      }
    },
    {
      "condition": "[variables('createNewVnet')]",
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2024-05-01",
      "name": "[variables('effectiveVnetName')]",
      "location": "[parameters('location')]",
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "[parameters('addressSpace')]"
          ]
        },
        "subnets": [
          {
            "name": "[variables('mgmtSubnetName')]",
            "properties": {
              "addressPrefix": "[parameters('mgmtSubnetPrefix')]"
            }
          },
          {
            "name": "[variables('ingressSubnetName')]",
            "properties": {
              "addressPrefix": "[parameters('ingressSubnetPrefix')]"
            }
          },
          {
            "name": "[variables('egressSubnetName')]",
            "properties": {
              "addressPrefix": "[parameters('egressSubnetPrefix')]"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2024-05-01",
      "name": "[variables('mgmtNicName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/publicIPAddresses', variables('pipName'))]",
        "[resourceId('Microsoft.Network/networkSecurityGroups', variables('nsgName'))]",
        "[resourceId('Microsoft.Network/virtualNetworks', variables('effectiveVnetName'))]"
      ],
      "properties": {
        "enableAcceleratedNetworking": false,
        "ipConfigurations": [
          {
            "name": "ipconfig1",
            "properties": {
              "subnet": {
                "id": "[variables('mgmtSubnetId')]"
              },
              "publicIPAddress": {
                "id": "[resourceId('Microsoft.Network/publicIPAddresses', variables('pipName'))]"
              },
              "privateIPAllocationMethod": "Dynamic"
            }
          }
        ],
        "networkSecurityGroup": {
          "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('nsgName'))]"
        }
      }
    },
    {
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2024-05-01",
      "name": "[variables('ingressNicName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', variables('effectiveVnetName'))]"
      ],
      "properties": {
        "enableAcceleratedNetworking": true,
        "enableIPForwarding": true,
        "ipConfigurations": [
          {
            "name": "ipconfig1",
            "properties": {
              "subnet": {
                "id": "[variables('ingressSubnetId')]"
              },
              "privateIPAllocationMethod": "Dynamic"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2024-05-01",
      "name": "[variables('egressNicName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', variables('effectiveVnetName'))]"
      ],
      "properties": {
        "enableAcceleratedNetworking": true,
        "enableIPForwarding": true,
        "ipConfigurations": [
          {
            "name": "ipconfig1",
            "properties": {
              "subnet": {
                "id": "[variables('egressSubnetId')]"
              },
              "privateIPAllocationMethod": "Dynamic"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Compute/virtualMachines",
      "apiVersion": "2024-11-01",
      "name": "[parameters('vmName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkInterfaces', variables('mgmtNicName'))]",
        "[resourceId('Microsoft.Network/networkInterfaces', variables('ingressNicName'))]",
        "[resourceId('Microsoft.Network/networkInterfaces', variables('egressNicName'))]"
      ],
      "plan": {
        "name": "cloudlens-virtual-packet-broker-3-15-0_1",
        "publisher": "keysight-technologies-cloudlens",
        "product": "keysight-cloudlens-virtual-packet-broker"
      },
      "properties": {
        "hardwareProfile": {
          "vmSize": "[parameters('vmSize')]"
        },
        "osProfile": {
          "computerName": "[parameters('vmName')]",
          "adminUsername": "[parameters('adminUsername')]",
          "adminPassword": "[parameters('adminPassword')]"
        },
        "storageProfile": {
          "imageReference": {
            "publisher": "[variables('imagePublisher')]",
            "offer": "[variables('imageOffer')]",
            "sku": "[variables('imageSku')]",
            "version": "latest"
          },
          "osDisk": {
            "createOption": "FromImage",
            "managedDisk": {
              "storageAccountType": "Premium_LRS"
            }
          }
        },
        "networkProfile": {
          "networkInterfaces": [
            {
              "id": "[resourceId('Microsoft.Network/networkInterfaces', variables('mgmtNicName'))]",
              "properties": {
                "primary": true
              }
            },
            {
              "id": "[resourceId('Microsoft.Network/networkInterfaces', variables('ingressNicName'))]",
              "properties": {
                "primary": false
              }
            },
            {
              "id": "[resourceId('Microsoft.Network/networkInterfaces', variables('egressNicName'))]",
              "properties": {
                "primary": false
              }
            }
          ]
        },
        "diagnosticsProfile": {
          "bootDiagnostics": {
            "enabled": true
          }
        }
      }
    }
  ],
  "outputs": {
    "vpbPublicIp": {
      "type": "string",
      "value": "[reference(variables('pipName')).ipAddress]"
    },
    "vpbSshCommand": {
      "type": "string",
      "value": "[concat('ssh -p 9022 ', parameters('adminUsername'), '@', reference(variables('pipName')).ipAddress)]"
    },
    "vpbCliAccess": {
      "type": "string",
      "value": "[concat('First-time setup (run once after first SSH): curl -sSL https://raw.githubusercontent.com/Keysight-Tech/cloudlens-ansible-azure/main/scripts/bootstrap-vpb.sh | sudo bash. Then log out, ssh -p 9022 ', parameters('adminUsername'), '@', reference(variables('pipName')).ipAddress, ', and run: sudo vpb. See docs/OPERATIONS.md section 2.')]"
    },
    "nextStep": {
      "type": "string",
      "value": "[concat('vPB is initializing (about 5-10 minutes). Step 1: SSH on port 9022 -> ssh -p 9022 ', parameters('adminUsername'), '@', reference(variables('pipName')).ipAddress, '. Step 2: run the one-time bootstrap (installs kubeconfig + sudo vpb wrapper) -> curl -sSL https://raw.githubusercontent.com/Keysight-Tech/cloudlens-ansible-azure/main/scripts/bootstrap-vpb.sh | sudo bash. Step 3: log out, SSH back in, run: sudo kubectl get pods -A and sudo vpb.')]"
    }
  }
}

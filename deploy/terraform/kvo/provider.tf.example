###############################################################################
# Standalone provider configuration for the KVO module
#
# Copy this file to provider.tf when running the module by itself:
#   cp provider.tf.example provider.tf
#
# It is NOT included by default so the module can be wrapped by the stack
# module (deploy/terraform/stack/) with count or for_each.
###############################################################################

provider "azurerm" {
  features {}

  subscription_id = var.subscription_id
  tenant_id       = var.tenant_id != "" ? var.tenant_id : null
}

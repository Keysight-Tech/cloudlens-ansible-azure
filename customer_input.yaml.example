# =====================================================================
# CloudLens Ansible — Azure Customer Input
# =====================================================================
# Copy this file to customer_input.yaml and fill in the values.
# Sensitive values (passwords) should be in environment variables —
# never commit customer_input.yaml to git.
# =====================================================================

# === Azure Environment ===
azure:
  subscription_id: "00000000-0000-0000-0000-000000000000"
  tenant_id: "00000000-0000-0000-0000-000000000000"

  # Resource groups to scan for VMs (Ansible azure_rm dynamic inventory)
  resource_groups:
    - "customer-prod-rg"
    # - "customer-prod-windows-rg"

  # Optional location filter (if empty, all locations scanned)
  locations:
    - "eastus2"
    # - "westeurope"

  # Tag selector — only VMs with these tags will be deployed to.
  # In Azure portal / CLI, tag your VMs with:
  #   cloudlens=yes  os=ubuntu|rhel|windows  env=prod
  tag_filters:
    cloudlens: "yes"
    env: "prod"

# === CloudLens Configuration ===
cloudlens:
  # CloudLens Manager (CLMS) public IP or FQDN reachable from VMs
  manager_ip_or_fqdn: "clms.customer.example.com"

  # Project key from CLMS → Projects → API Keys
  project_key: "REPLACE_WITH_PROJECT_KEY"

  # Tags attached to every registered sensor (visible in CLMS UI)
  custom_tags: "Env=Azure Region=eastus2 Customer=Acme"

  # "insecure" for self-signed CLMS; "secure" if you have a signed CA bundle
  registry_type: "insecure"
  ssl_verify: "no"
  auto_update: "yes"

  # Only used when registry_type=secure
  local_ca_path: "files/cloudlenscerts.crt"
  ca_cert_dir: "/etc/ssl/certs"

  # Container settings
  agent_container_name: "cloudlens-agent"
  log_max_size: "50m"
  log_max_file: "5"

# === Linux SSH Connection ===
linux:
  ansible_user: "azureuser"
  ssh_key_file: "~/.ssh/id_rsa"
  # Set to true if you use Azure Bastion (additional config in docs/)
  use_bastion: false

# === Windows WinRM Connection ===
windows:
  ansible_user: "azureuser"
  # IMPORTANT: do NOT put password here. Export instead:
  #   export ANSIBLE_WINRM_PASSWORD='your-password'
  ansible_password: "{{ lookup('env', 'ANSIBLE_WINRM_PASSWORD') }}"
  ansible_connection: "winrm"
  ansible_winrm_transport: "ntlm"
  ansible_winrm_server_cert_validation: "ignore"

  # Local path to CloudLens Windows installer (download separately)
  installer_path: "files/cloudlens-win-sensor-6.12.0.316.exe"
  installer_filename: "cloudlens-win-sensor-6.12.0.316.exe"

# === Deployment Behavior ===
deploy:
  forks: 20                  # parallel VMs (Ansible workers)
  timeout_seconds: 60        # per-task SSH/WinRM timeout
  reinstall_if_unhealthy: true

{
  "$schema": "https://schema.management.azure.com/schemas/0.1.2-preview/CreateUIDefinition.MultiVm.json#",
  "handler": "Microsoft.Azure.CreateUIDef",
  "version": "0.1.2-preview",
  "parameters": {
    "config": {
      "isWizard": true,
      "basics": {
        "description": "Deploying the full Keysight CloudLens stack in a single click. This stands up vController (control plane), KVO (orchestrator), and vPB (data plane) into a shared VNet with five purpose-built subnets. Total deploy time is about 15 minutes. After deploy, the outputs include a one-line Cloud Shell command that installs CloudLens sensors on tagged workload VMs.",
        "subscription": {},
        "resourceGroup": {
          "allowExisting": true
        },
        "location": {
          "label": "Region",
          "toolTip": "Azure region for all three VMs and the shared VNet. Pick the region closest to your monitored workloads."
        }
      }
    },
    "basics": [],
    "steps": [
      {
        "name": "stackConfig",
        "label": "Stack",
        "subLabel": {
          "preValidation": "Configure the CloudLens stack",
          "postValidation": "Done"
        },
        "bladeTitle": "Stack",
        "elements": [
          {
            "name": "intro",
            "type": "Microsoft.Common.InfoBox",
            "visible": true,
            "options": {
              "icon": "Info",
              "text": "**About the prefix:** the name you pick becomes the prefix for every VM and resource. The VMs will be `<prefix>-vcontroller`, `<prefix>-kvo`, `<prefix>-vpb`. For multi-region deployments, use a region-suffixed prefix like `cloudlens-eastus` so each region's stack has unique names."
            }
          },
          {
            "name": "namePrefix",
            "type": "Microsoft.Common.TextBox",
            "label": "Name prefix",
            "defaultValue": "cloudlens",
            "toolTip": "Used as the prefix for all VMs, NICs, NSGs, public IPs, and the shared VNet. 3 to 32 characters, lowercase letters, digits, hyphens; must start and end with a letter or digit.",
            "constraints": {
              "required": true,
              "regex": "^[a-z0-9][a-z0-9-]{1,30}[a-z0-9]$",
              "validationMessage": "3 to 32 characters. Lowercase letters, digits, hyphens. Must start and end with a letter or digit."
            }
          },
          {
            "name": "countsHeader",
            "type": "Microsoft.Common.Section",
            "label": "Instance counts (advanced)",
            "elements": [
              {
                "name": "countsInfoBox",
                "type": "Microsoft.Common.InfoBox",
                "visible": true,
                "options": {
                  "icon": "Info",
                  "text": "**Default is 1 of each.** For HA, multi-region, or scale-out you can deploy multiple of each product. Names get auto-indexed: `<prefix>-vcontroller-1`, `-2`, `-3`. All instances share the same shared VNet. Each vPB also gets its own ingress + egress NICs."
                }
              },
              {
                "name": "vcontrollerCount",
                "type": "Microsoft.Common.DropDown",
                "label": "vController count",
                "defaultValue": "1 (default)",
                "toolTip": "Number of vController VMs. 1 = default. 2 = HA active/standby. 3 = multi-region or BU-isolation.",
                "constraints": {
                  "allowedValues": [
                    {
                      "label": "1 (default)",
                      "value": 1
                    },
                    {
                      "label": "2 (HA active/standby)",
                      "value": 2
                    },
                    {
                      "label": "3 (multi-region / BU isolation)",
                      "value": 3
                    }
                  ],
                  "required": true
                }
              },
              {
                "name": "kvoCount",
                "type": "Microsoft.Common.DropDown",
                "label": "KVO count",
                "defaultValue": "1 (default)",
                "toolTip": "Number of KVO VMs. 1 = default. 2 = HA pair.",
                "constraints": {
                  "allowedValues": [
                    {
                      "label": "1 (default)",
                      "value": 1
                    },
                    {
                      "label": "2 (HA pair)",
                      "value": 2
                    }
                  ],
                  "required": true
                }
              },
              {
                "name": "vpbCount",
                "type": "Microsoft.Common.DropDown",
                "label": "vPB count",
                "defaultValue": "1 (default)",
                "toolTip": "Number of vPB VMs. Use 2-5 to scale out the data plane.",
                "constraints": {
                  "allowedValues": [
                    {
                      "label": "1 (default)",
                      "value": 1
                    },
                    {
                      "label": "2 (scale-out, 2 tools)",
                      "value": 2
                    },
                    {
                      "label": "3 (scale-out, 3 tools)",
                      "value": 3
                    },
                    {
                      "label": "4 (high throughput)",
                      "value": 4
                    },
                    {
                      "label": "5 (max scale)",
                      "value": 5
                    }
                  ],
                  "required": true
                }
              }
            ]
          },
          {
            "name": "customizeVmNames",
            "type": "Microsoft.Common.CheckBox",
            "label": "Override individual VM names (optional)",
            "defaultValue": false,
            "toolTip": "By default the VMs are named <prefix>-vcontroller, <prefix>-kvo, <prefix>-vpb (with -1, -2, -3 appended when count > 1). Tick this box to set custom base names per product. When count > 1 the custom name still gets the -N suffix appended."
          },
          {
            "name": "vcontrollerVmName",
            "type": "Microsoft.Common.TextBox",
            "label": "vController VM name (base)",
            "defaultValue": "",
            "toolTip": "Custom base name for vController. Blank = use <prefix>-vcontroller. With count > 1 the suffix -1, -2, -3 is appended automatically.",
            "constraints": {
              "required": false,
              "regex": "^$|^[a-z0-9][a-z0-9-]{1,40}[a-z0-9]$",
              "validationMessage": "Blank, or 3-42 chars lowercase / digits / hyphens. Must start and end with a letter or digit."
            },
            "visible": "[steps('stackConfig').customizeVmNames]"
          },
          {
            "name": "kvoVmName",
            "type": "Microsoft.Common.TextBox",
            "label": "KVO VM name (base)",
            "defaultValue": "",
            "toolTip": "Custom base name for KVO. Blank = use <prefix>-kvo.",
            "constraints": {
              "required": false,
              "regex": "^$|^[a-z0-9][a-z0-9-]{1,40}[a-z0-9]$",
              "validationMessage": "Blank, or 3-42 chars lowercase / digits / hyphens."
            },
            "visible": "[steps('stackConfig').customizeVmNames]"
          },
          {
            "name": "vpbVmName",
            "type": "Microsoft.Common.TextBox",
            "label": "vPB VM name (base)",
            "defaultValue": "",
            "toolTip": "Custom base name for vPB. Blank = use <prefix>-vpb.",
            "constraints": {
              "required": false,
              "regex": "^$|^[a-z0-9][a-z0-9-]{1,40}[a-z0-9]$",
              "validationMessage": "Blank, or 3-42 chars lowercase / digits / hyphens."
            },
            "visible": "[steps('stackConfig').customizeVmNames]"
          },
          {
            "name": "adminUsername",
            "type": "Microsoft.Compute.UserNameTextBox",
            "label": "Linux admin username",
            "defaultValue": "azureuser",
            "toolTip": "OS-level admin user for SSH. Shared across vController, KVO, and vPB.",
            "osPlatform": "Linux",
            "constraints": {
              "required": true
            }
          },
          {
            "name": "passwordInfoBox",
            "type": "Microsoft.Common.InfoBox",
            "visible": true,
            "options": {
              "icon": "Info",
              "text": "Heads-up: the password below is for **OS-level SSH** on all three VMs. The vController **web UI** uses built-in credentials (`admin / Cl0udLens@dm!n`) you'll change on first login. The KVO **web UI** admin account is set during first-login EULA acceptance. The vPB **CLI** is reached through a two-hop SSH and has its own credentials. All separate from this password."
            }
          },
          {
            "name": "adminPassword",
            "type": "Microsoft.Compute.CredentialsCombo",
            "label": {
              "password": "Linux admin password",
              "confirmPassword": "Confirm password"
            },
            "toolTip": {
              "password": "Shared OS-level password for all three VMs. 12+ chars, upper, lower, digit, symbol. NOT the web UI password."
            },
            "osPlatform": "Linux",
            "constraints": {
              "required": true
            },
            "options": {
              "hideConfirmation": false,
              "hidePassword": false
            }
          },
          {
            "name": "sizesHeader",
            "type": "Microsoft.Common.Section",
            "label": "VM sizes",
            "elements": [
              {
                "name": "vcontrollerVmSize",
                "type": "Microsoft.Common.DropDown",
                "label": "vController VM size",
                "defaultValue": "Standard_D4s_v5 (4 vCPU, 16 GB, recommended)",
                "toolTip": "vController size. Standard_D4s_v5 is sized for most deployments. Scale up for thousands of sensors.",
                "constraints": {
                  "allowedValues": [
                    {
                      "label": "Standard_D2s_v5 (2 vCPU, 8 GB, small dev/test)",
                      "value": "Standard_D2s_v5"
                    },
                    {
                      "label": "Standard_D4s_v5 (4 vCPU, 16 GB, recommended)",
                      "value": "Standard_D4s_v5"
                    },
                    {
                      "label": "Standard_D8s_v5 (8 vCPU, 32 GB, large fleets)",
                      "value": "Standard_D8s_v5"
                    },
                    {
                      "label": "Standard_D16s_v5 (16 vCPU, 64 GB, very large fleets)",
                      "value": "Standard_D16s_v5"
                    }
                  ],
                  "required": true
                }
              },
              {
                "name": "kvoVmSize",
                "type": "Microsoft.Common.DropDown",
                "label": "KVO VM size",
                "defaultValue": "Standard_D4s_v5 (4 vCPU, 16 GB, recommended)",
                "toolTip": "KVO size. Standard_D4s_v5 is sized for most deployments.",
                "constraints": {
                  "allowedValues": [
                    {
                      "label": "Standard_D2s_v5 (2 vCPU, 8 GB, small dev/test)",
                      "value": "Standard_D2s_v5"
                    },
                    {
                      "label": "Standard_D4s_v5 (4 vCPU, 16 GB, recommended)",
                      "value": "Standard_D4s_v5"
                    },
                    {
                      "label": "Standard_D8s_v5 (8 vCPU, 32 GB, large fleets)",
                      "value": "Standard_D8s_v5"
                    }
                  ],
                  "required": true
                }
              },
              {
                "name": "vpbVmSize",
                "type": "Microsoft.Common.DropDown",
                "label": "vPB VM size",
                "defaultValue": "Standard_D8s_v3 (8 vCPU, 32 GB, minimum for 3 NICs)",
                "toolTip": "vPB size. Minimum Standard_D8s_v3 is required for three accelerated NICs.",
                "constraints": {
                  "allowedValues": [
                    {
                      "label": "Standard_D8s_v3 (8 vCPU, 32 GB, minimum for 3 NICs)",
                      "value": "Standard_D8s_v3"
                    },
                    {
                      "label": "Standard_D16s_v3 (16 vCPU, 64 GB, higher mirror throughput)",
                      "value": "Standard_D16s_v3"
                    },
                    {
                      "label": "Standard_D32s_v3 (32 vCPU, 128 GB, max throughput)",
                      "value": "Standard_D32s_v3"
                    }
                  ],
                  "required": true
                }
              },
              {
                "name": "vpbNicInfoBox",
                "type": "Microsoft.Common.InfoBox",
                "visible": true,
                "options": {
                  "icon": "Info",
                  "text": "**vPB NIC layout:** 1 mgmt NIC + N ingress + N egress. Default is 1 of each (3 NICs total). For fan-in / fan-out prod use 2-3 of each. With more than 3 data NICs you must select D16s_v3 or D32s_v3 above (D8s_v3 supports max 4 NICs)."
                }
              },
              {
                "name": "vpbIngressNicCount",
                "type": "Microsoft.Common.DropDown",
                "label": "vPB ingress NIC count",
                "defaultValue": "1 (default)",
                "toolTip": "vPB receive-side NICs.",
                "constraints": {
                  "allowedValues": [
                    {
                      "label": "1 (default)",
                      "value": 1
                    },
                    {
                      "label": "2 (two mirror sources)",
                      "value": 2
                    },
                    {
                      "label": "3 (three sources, needs D16s_v3+)",
                      "value": 3
                    }
                  ],
                  "required": true
                }
              },
              {
                "name": "vpbEgressNicCount",
                "type": "Microsoft.Common.DropDown",
                "label": "vPB egress NIC count",
                "defaultValue": "1 (default)",
                "toolTip": "vPB forward-side NICs.",
                "constraints": {
                  "allowedValues": [
                    {
                      "label": "1 (default)",
                      "value": 1
                    },
                    {
                      "label": "2 (two tools)",
                      "value": 2
                    },
                    {
                      "label": "3 (three tools, needs D16s_v3+)",
                      "value": 3
                    }
                  ],
                  "required": true
                }
              }
            ]
          },
          {
            "name": "networkHeader",
            "type": "Microsoft.Common.Section",
            "label": "Shared network",
            "elements": [
              {
                "name": "networkInfoBox",
                "type": "Microsoft.Common.InfoBox",
                "visible": true,
                "options": {
                  "icon": "Info",
                  "text": "The stack creates ONE shared VNet with five subnets: vcontroller-subnet (10.50.1.0/24), kvo-subnet (10.50.2.0/24), vpb-mgmt (10.50.10.0/24), vpb-ingress (10.50.11.0/24), vpb-egress (10.50.12.0/24). Override the address space below if your default range conflicts."
                }
              },
              {
                "name": "vnetAddressSpace",
                "type": "Microsoft.Common.TextBox",
                "label": "Shared VNet address space (CIDR)",
                "defaultValue": "10.50.0.0/16",
                "toolTip": "CIDR for the shared VNet. The five subnets carve from this. Must not overlap with VNets you plan to peer with.",
                "constraints": {
                  "required": true,
                  "regex": "^([0-9]{1,3}\\.){3}[0-9]{1,3}/[0-9]{1,2}$",
                  "validationMessage": "Enter a valid CIDR (for example, 10.50.0.0/16)."
                }
              }
            ]
          }
        ]
      }
    ],
    "outputs": {
      "namePrefix": "[steps('stackConfig').namePrefix]",
      "adminUsername": "[steps('stackConfig').adminUsername]",
      "adminPassword": "[steps('stackConfig').adminPassword.password]",
      "vcontrollerVmSize": "[steps('stackConfig').sizesHeader.vcontrollerVmSize]",
      "kvoVmSize": "[steps('stackConfig').sizesHeader.kvoVmSize]",
      "vpbVmSize": "[steps('stackConfig').sizesHeader.vpbVmSize]",
      "location": "[location()]",
      "vnetAddressSpace": "[steps('stackConfig').networkHeader.vnetAddressSpace]",
      "vpbIngressNicCount": "[steps('stackConfig').sizesHeader.vpbIngressNicCount]",
      "vpbEgressNicCount": "[steps('stackConfig').sizesHeader.vpbEgressNicCount]",
      "vcontrollerCount": "[steps('stackConfig').countsHeader.vcontrollerCount]",
      "kvoCount": "[steps('stackConfig').countsHeader.kvoCount]",
      "vpbCount": "[steps('stackConfig').countsHeader.vpbCount]",
      "vcontrollerVmName": "[steps('stackConfig').vcontrollerVmName]",
      "kvoVmName": "[steps('stackConfig').kvoVmName]",
      "vpbVmName": "[steps('stackConfig').vpbVmName]"
    }
  }
}
